# =============================================================================
# The Global Staring Contest — Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
# Format: postgresql+asyncpg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/noblink

# ── Redis ────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── ML / Blink Detection ────────────────────────────────────────────────────
# Eye Aspect Ratio threshold — below this = eyes closing (default: 0.21)
EAR_THRESHOLD=0.21
# Consecutive frames below threshold to confirm a blink (default: 2)
EAR_CONSEC_FRAMES=2

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Server ───────────────────────────────────────────────────────────────────
APP_NAME="The Global Staring Contest"
DEBUG=true
